# Copy to .env and fill in. .env is git-ignored — NEVER commit real secrets.
# Functions read these via process.env (Netlify dashboard in prod; .env locally
# when running `netlify dev`).

# Airtable Personal Access Token (used by BOTH functions). SECRET — leave blank here.
AIRTABLE_API_KEY=

# Main NEE base (jobs, employees, time, invoices, etc.)
AIRTABLE_BASE_ID=appiqWg6SvKcGfMAu

# Separate inventory/materials base (inventory.js only)
INVENTORY_BASE_ID=appfsLJwfow4CepCw

# Google Maps Distance Matrix — handleCalculateMileage. SECRET — leave blank here.
GOOGLE_MAPS_API_KEY=

# Gates the one-off backfillTimeEntryEmployeeLinks admin action. SECRET.
ADMIN_BACKFILL_TOKEN=

# HMAC key for signing/verifying session tokens (_auth.js, shared by both functions).
# SECRET. REQUIRED — auth fails closed: every request 401s if this is unset. Use a long
# random string (e.g. `openssl rand -hex 32`). For local dev/tests any non-empty value works.
AUTH_SECRET=

# ── LOCAL TESTING SAFETY ──
# For local `netlify dev`, point the two base IDs at a DUPLICATED sandbox base
# so write paths (expense push, payroll, invoices) never touch production data:
#   AIRTABLE_BASE_ID=app<your-test-base>
#   INVENTORY_BASE_ID=app<your-test-inventory-base>
